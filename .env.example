# 腾讯云 API SecretId，建议使用仅包含域名注册所需权限的子账号密钥
TENCENTCLOUD_SECRET_ID=

# 腾讯云 API SecretKey，不要提交真实密钥
TENCENTCLOUD_SECRET_KEY=

# 已实名审核通过的腾讯云域名信息模板 ID，格式通常类似 tmpl-xxxxxx
TENCENT_DOMAIN_TEMPLATE_ID=

# 需要监听的域名，多个域名用英文逗号分隔
DOMAIN_WATCH_DOMAINS=example.com,example.net

# 普通监听间隔，单位秒；默认 1 天，适合低频观察非热门域名
DOMAIN_WATCH_INTERVAL_SECONDS=86400

# 域名已过期后的监听间隔，单位秒；默认同样 1 天
DOMAIN_WATCH_EXPIRED_INTERVAL_SECONDS=86400

# 注册年限，默认 1 年
DOMAIN_PERIOD=1

# domain-check 可执行文件路径；如果不在 PATH 中，可以写完整路径
DOMAIN_CHECK_BIN=domain-check

# 监听状态文件路径；已提交注册任务的域名会从 active 列表移出并写入这里
DOMAIN_WATCH_STATE_FILE=domain_watch_state.json

# onepush 推送渠道；留空表示不启用推送
# 示例：bark / telegram / serverchan / serverchanturbo / pushplus / dingtalk / lark
ONEPUSH_PROVIDER=

# onepush 渠道参数，必须是 JSON 对象；不同渠道需要的 key 不同
# Bark 示例：{"key":"你的 Bark key"}
# Telegram 示例：{"token":"bot token","userid":"chat id"}
ONEPUSH_PARAMS_JSON=

# 推送标题前缀
ONEPUSH_TITLE_PREFIX=[domain-watch] 
